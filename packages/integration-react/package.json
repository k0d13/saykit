{
  "name": "@saykit/react",
  "version": "0.0.1",
  "description": "React integration for saykit, i18n hooks and components",
  "keywords": [
    "i18n",
    "internationalization",
    "react",
    "saykit"
  ],
  "homepage": "https://github.com/k0d13/saykit#readme",
  "bugs": {
    "url": "https://github.com/k0d13/saykit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k0d13/saykit.git",
    "directory": "packages/integration-react"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "react-server": "./dist/index.server.mjs",
      "default": "./dist/index.client.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsdown",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "react": "^19.2.4",
    "saykit": "workspace:^"
  },
  "peerDependencies": {
    "react": "*",
    "saykit": "*"
  }
}
