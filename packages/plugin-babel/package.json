{
  "name": "@saykit/babel-plugin",
  "version": "0.0.0",
  "description": "Babel plugin for saykit macro transforms",
  "keywords": [
    "babel",
    "i18n",
    "macros",
    "plugin",
    "saykit",
    "transform"
  ],
  "homepage": "https://github.com/k0d13/saykit#readme",
  "bugs": {
    "url": "https://github.com/k0d13/saykit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k0d13/saykit.git",
    "directory": "packages/plugin-babel"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.mts",
      "default": "./dist/core/index.mjs"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "tsdown",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "js-sha256": "^0.11.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0"
  }
}
