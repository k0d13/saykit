{
  "name": "@saykit/babel-plugin",
  "version": "0.0.0",
  "description": "Babel plugin for SayKit",
  "keywords": [
    "i18n",
    "rollup",
    "saykit",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/k0d13/saykit#readme",
  "bugs": {
    "url": "https://github.com/k0d13/saykit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k0d13/saykit.git",
    "directory": "packages/plugin-babel"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsdown",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/parser": "^7.29.2",
    "@saykit/config": "workspace:^",
    "@types/babel__core": "^7.20.5"
  },
  "devDependencies": {
    "@types/babel__parser": "^7.1.5"
  }
}
