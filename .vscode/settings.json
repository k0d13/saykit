{
  "explorer.compactFolders": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, pnpm-workspace.yaml",
    "*.ts": "$(capture).test.ts",
    "*.js": "$(capture).js.map, $(capture).d.ts, $(capture).d.ts.map, $(capture).cjs",
    "*.cjs": "$(capture).cjs.map, $(capture).d.cts, $(capture).d.cts.map"
  },

  "editor.insertSpaces": true,
  "editor.tabSize": 2,

  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "js/ts.preferences.importModuleSpecifierEnding": "js",
    "js/ts.inlayHints.parameterNames.enabled": "all",
    "js/ts.inlayHints.variableTypes.suppressWhenTypeMatchesName": true
  },

  // Code Spell Checker
  "cSpell.language": "en-GB",
  "cSpell.words": ["saykit", "unplugin"],

  // Todo Tree
  "todo-tree.general.tags": ["=====", "TODO"],
  "todo-tree.highlights.customHighlight": {
    "=====": {
      "type": "whole-line",
      "icon": "bookmark",
      "foreground": "#dadada",
      "gutterIcon": true,
      "hideFromTree": true
    },
    "TODO": {
      "type": "whole-line",
      "icon": "check",
      "foreground": "#ff9900",
      "gutterIcon": true
    }
  }
}
